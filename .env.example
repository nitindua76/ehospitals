# Database URI (Internal Docker network address)
MONGO_URI=mongodb://mongodb:27017/hospital_selection

# 🔐 JWT Secret (Required)
# Use a long, random string (at least 64 chars) for production
JWT_SECRET=your_super_secret_jwt_key_here_change_me

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123

# Server Port
PORT=5000
